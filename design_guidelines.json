{
  "brand_identity": {
    "name": "Aspiiro",
    "core_concept": "Swiss Brutalist Streetwear",
    "emotional_archetype": "Authority & Clarity (Swiss Style)",
    "vibe": "Modern, Minimal, Premium, Urban",
    "target_audience": "Indian Gen Z/Millennials, Mobile-First",
    "design_principles": [
      "Content is King: Product photography dominates the screen.",
      "Fusion: Swiss Typography meets Streetwear Grime.",
      "Contrast: Stark Black & White. No mid-tones.",
      "Asymmetry: Tension in layout creates interest."
    ]
  },
  "typography": {
    "font_family_heading": "Syne, sans-serif",
    "font_family_body": "Manrope, sans-serif",
    "import_url": "https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700&family=Syne:wght@400;700;800&display=swap",
    "rules": {
      "headings": "Uppercase, Tight Tracking (tracking-tighter), Bold (font-bold or font-extrabold).",
      "body": "Clean, Readable, Relaxed Line Height (leading-relaxed).",
      "captions": "Monospace feel, Uppercase, Wide Tracking (tracking-widest)."
    }
  },
  "colors": {
    "palette": {
      "light": {
        "background": "#FFFFFF",
        "foreground": "#000000",
        "card": "#FFFFFF",
        "card_foreground": "#000000",
        "popover": "#FFFFFF",
        "popover_foreground": "#000000",
        "primary": "#000000",
        "primary_foreground": "#FFFFFF",
        "secondary": "#F4F4F5",
        "secondary_foreground": "#18181B",
        "muted": "#F4F4F5",
        "muted_foreground": "#71717A",
        "accent": "#F4F4F5",
        "accent_foreground": "#18181B",
        "destructive": "#EF4444",
        "destructive_foreground": "#FAFAFA",
        "border": "#E4E4E7",
        "input": "#E4E4E7",
        "ring": "#18181B"
      },
      "dark": {
        "background": "#050505",
        "foreground": "#FAFAFA",
        "card": "#050505",
        "card_foreground": "#FAFAFA",
        "popover": "#050505",
        "popover_foreground": "#FAFAFA",
        "primary": "#FAFAFA",
        "primary_foreground": "#18181B",
        "secondary": "#27272A",
        "secondary_foreground": "#FAFAFA",
        "muted": "#27272A",
        "muted_foreground": "#A1A1AA",
        "accent": "#27272A",
        "accent_foreground": "#FAFAFA",
        "destructive": "#7F1D1D",
        "destructive_foreground": "#FAFAFA",
        "border": "#27272A",
        "input": "#27272A",
        "ring": "#D4D4D8"
      }
    },
    "special_accents": {
      "brand_accent": "#FF3300",
      "sale_badge": "#FF3300",
      "success": "#00C853"
    }
  },
  "layout_strategies": {
    "container": "max-w-7xl mx-auto px-4 sm:px-6 lg:px-8",
    "spacing": {
      "section_gap": "py-24 md:py-32",
      "element_gap": "gap-6 md:gap-12"
    },
    "grids": {
      "product_grid": "grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-4 gap-y-12",
      "bento_grid": "grid grid-cols-1 md:grid-cols-4 gap-4 auto-rows-[400px]"
    }
  },
  "components": {
    "buttons": {
      "style": "sharp",
      "border_radius": "rounded-none",
      "classes": "uppercase tracking-widest font-bold border-2 border-black hover:bg-black hover:text-white transition-all duration-300"
    },
    "cards": {
      "style": "minimal",
      "border_radius": "rounded-none",
      "shadow": "none",
      "border": "border border-gray-100 hover:border-black transition-colors duration-300"
    },
    "inputs": {
      "style": "underlined",
      "classes": "border-b-2 border-gray-200 focus:border-black rounded-none bg-transparent px-0"
    }
  },
  "visual_assets": {
    "hero_images": [
      "https://images.pexels.com/photos/35465936/pexels-photo-35465936.jpeg",
      "https://images.pexels.com/photos/35447242/pexels-photo-35447242.jpeg"
    ],
    "product_images": {
      "hoodies": [
        "https://images.pexels.com/photos/17756714/pexels-photo-17756714.jpeg",
        "https://images.pexels.com/photos/7709608/pexels-photo-7709608.jpeg"
      ],
      "tshirts": [
        "https://images.pexels.com/photos/8148576/pexels-photo-8148576.jpeg",
        "https://images.pexels.com/photos/5325899/pexels-photo-5325899.jpeg"
      ],
      "pants": [
        "https://images.pexels.com/photos/9695913/pexels-photo-9695913.jpeg",
        "https://images.pexels.com/photos/7255427/pexels-photo-7255427.jpeg"
      ]
    },
    "icons": "lucide-react"
  },
  "motion": {
    "library": "framer-motion",
    "defaults": {
      "duration": 0.4,
      "ease": "easeOut"
    },
    "page_transition": {
      "initial": { "opacity": 0, "y": 20 },
      "animate": { "opacity": 1, "y": 0 },
      "exit": { "opacity": 0, "y": -20 }
    }
  },
  "universal_guidelines": [
    "DO NOT use gradients. Stick to solid colors.",
    "DO NOT use rounded corners > 4px. Keep it sharp.",
    "Ensure all text has sufficient contrast (APCA standards).",
    "Mobile-first: Ensure touch targets are at least 44px.",
    "Use 'data-testid' on all interactive elements.",
    "Images must be lazy-loaded.",
    "Use 'sonner' for toast notifications.",
    "Use 'lucide-react' for icons."
  ],
  "instructions_to_main_agent": "You are building the frontend for Aspiiro. Use the provided colors and typography to configure Tailwind. Build the components using Shadcn/UI logic but override the styles to match the 'Swiss Brutalist' aesthetic defined here. Focus on the Homepage first, then the Product Listing and Detail pages. Ensure the Admin panel is functional but clean."
}